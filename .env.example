# Nexus Code Agent - Environment Variables

# Server Configuration
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8000
NEXUS_DEBUG=false

# LLM Provider Configuration
LLM_PROVIDER=ollama
LLM_MODEL=llama2
LLM_API_KEY=
LLM_ENDPOINT=http://localhost:11434

# Storage
STORAGE_PATH=./projects

# Environment
ENVIRONMENT=development
