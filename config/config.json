{
  "version": "1.0.0",
  "app_name": "Nexus Code Agent",
  "server": {
    "host": "0.0.0.0",
    "port": 8000,
    "debug": false
  },
  "llm": {
    "provider": "ollama",
    "model": "llama2",
    "api_key": "",
    "endpoint": "http://localhost:11434"
  },
  "storage": {
    "base_path": "./projects",
    "max_project_size": 1000000000
  },
  "security": {
    "allowed_domains": ["localhost", "127.0.0.1"],
    "cors_enabled": true
  }
}
